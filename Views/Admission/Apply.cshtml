@model Class11Admission.Models.Application

@{
    ViewData["Title"] = "Apply for Class 11";
}

<div class="container mt-4">
    <h2>Class 11 Admission Application Form</h2>
    <p class="text-muted">Session 2025-26 | Fill all details carefully</p>
    <hr />

    <form asp-action="Apply" method="post">
        @Html.AntiForgeryToken()

        <h5 class="mt-4">Personal Information</h5>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DateOfBirth" class="form-label"></label>
            <input asp-for="DateOfBirth" class="form-control" type="date" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Gender" class="form-label"></label>
            <select asp-for="Gender" class="form-select">
                <option value="">-- Select --</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </select>
            <span asp-validation-for="Gender" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MobileNumber" class="form-label"></label>
            <input asp-for="MobileNumber" class="form-control" placeholder="10-digit mobile number" />
            <span asp-validation-for="MobileNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" placeholder="your@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <h5 class="mt-4">Academic Information</h5>

        <div class="mb-3">
            <label asp-for="PreviousSchool" class="form-label"></label>
            <input asp-for="PreviousSchool" class="form-control" placeholder="Name of your Class 10 school" />
            <span asp-validation-for="PreviousSchool" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Board" class="form-label"></label>
            <select asp-for="Board" class="form-select">
                <option value="">-- Select Board --</option>
                <option value="CBSE">CBSE</option>
                <option value="ICSE">ICSE</option>
                <option value="State Board">State Board</option>
            </select>
            <span asp-validation-for="Board" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Percentage" class="form-label"></label>
            <input asp-for="Percentage" class="form-control" placeholder="e.g. 85.5" />
            <span asp-validation-for="Percentage" class="text-danger"></span>
        </div>

        <h5 class="mt-4">Stream Preference</h5>

        <div class="mb-3">
            <label asp-for="Stream" class="form-label"></label>
            <select asp-for="Stream" class="form-select">
                <option value="">-- Select Stream --</option>
                <option value="Science">Science (PCM / PCB)</option>
                <option value="Commerce">Commerce</option>
                <option value="Arts">Arts / Humanities</option>
            </select>
            <span asp-validation-for="Stream" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary mt-3">Submit Application</button>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}