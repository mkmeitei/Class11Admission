@{
    ViewData["Title"] = "Application Submitted";
}

<div class="container mt-5 text-center">
    <div class="alert alert-success p-5">
        <h2>✅ Application Submitted Successfully!</h2>
        <p class="mt-3">Your Tracking ID is:</p>
        <h3 class="fw-bold text-primary">@ViewBag.TrackingId</h3>
        <p class="mt-3 text-muted">
            Please save this ID. You can use it to check your application status.
        </p>
        <a asp-action="CheckStatus" class="btn btn-outline-primary mt-2">
            Check My Status
        </a>
    </div>
</div>