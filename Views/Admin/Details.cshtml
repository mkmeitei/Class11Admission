@model Class11Admission.Models.Application

@{
    ViewData["Title"] = "Application Details";
}

<div class="container mt-4">
    <h3>Application Details</h3>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Dashboard
    </a>

    <div class="card">
        <div class="card-body">

            <h5 class="card-title">@Model.FullName</h5>
            <hr />

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Tracking ID:</strong> @Model.TrackingId</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToShortDateString()</p>
                    <p><strong>Gender:</strong> @Model.Gender</p>
                    <p><strong>Mobile:</strong> @Model.MobileNumber</p>
                    <p><strong>Email:</strong> @Model.Email</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Previous School:</strong> @Model.PreviousSchool</p>
                    <p><strong>Board:</strong> @Model.Board</p>
                    <p><strong>Class 10 Percentage:</strong> @Model.Percentage%</p>
                    <p><strong>Stream Applied:</strong> @Model.Stream</p>
                    <p><strong>Applied On:</strong> @Model.AppliedOn.ToShortDateString()</p>
                </div>
            </div>

            <hr />

            <h6>Current Status:
                <span class="badge bg-secondary">@Model.Status</span>
            </h6>

            <div class="mt-3">
                <p><strong>Update Status:</strong></p>

                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <button type="submit" name="status" value="Approved"
                            class="btn btn-success me-2">
                        ✅ Approve
                    </button>
                    <button type="submit" name="status" value="Shortlisted"
                            class="btn btn-warning me-2">
                        ⭐ Shortlist
                    </button>
                    <button type="submit" name="status" value="Rejected"
                            class="btn btn-danger me-2">
                        ❌ Reject
                    </button>
                    <button type="submit" name="status" value="Pending"
                            class="btn btn-secondary">
                        ⏳ Mark Pending
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>